{
  "name": "@nilejs/future",
  "version": "0.1.0",
  "description": "High-performance actor and promise primitives for Bun and Node.js inspired by Erlang",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:vitest": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "bun run test && bun run typecheck && bun run bun-build.ts && tsc -p tsconfig.build.json"
  },
  "homepage": "https://github.com/Hussseinkizz/slang#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hussseinkizz/slang.git"
  },
  "bugs": {
    "url": "https://github.com/Hussseinkizz/slang/issues"
  },
  "keywords": [
    "actor",
    "supervisor",
    "worker-threads",
    "concurrency",
    "erlang",
    "fault-tolerance",
    "shared-memory",
    "agents",
    "typescript",
    "bun",
    "nodejs"
  ],
  "author": "Hussein Kizz",
  "license": "MIT",
  "sideEffects": false,
  "devDependencies": {
    "@types/bun": "latest",
    "@vitest/ui": "^4.0.15",
    "vitest": "^4.0.15"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "zod": "^3.23.0"
  }
}
